{
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "target": "app-principal",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "redirects": [
        {
          "source": "/alumnos",
          "destination": "/#/checkin?a=1:786390581865:web:ed47531cf7415ae5ca18f8",
          "type": 301
        }
      ],
      "rewrites": [
        { "source": "/sw-public.js", "destination": "/sw-public.js" },
        { "source": "/api/ytDownload", "function": "ytDownload" },
        { "source": "/api/ytSearch",   "function": "ytSearch"   },
        { "source": "/portal",         "destination": "/portal.html" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "/service-worker.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "text/javascript" }
          ]
        },
        {
          "source": "/sw-public.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "text/javascript" }
          ]
        },
        {
          "source": "/manifest-public.webmanifest",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
          ]
        },
        {
          "source": "/manifest-finanzas.webmanifest",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
          ]
        },
        {
          "source": "/",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/index.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/icon-*.png",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
            { "key": "Content-Type", "value": "image/png" }
          ]
        }
      ]
    },
    {
      "target": "catalogo-lenceria",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      
      "rewrites": [
        { "source": "/sw-public.js", "destination": "/sw-public.js" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "/service-worker.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "text/javascript" }
          ]
        },
        {
          "source": "/sw-public.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "text/javascript" }
          ]
        },
        {
          "source": "/manifest-public.webmanifest",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
          ]
        },
        {
          "source": "/icon-*.png",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
            { "key": "Content-Type", "value": "image/png" }
          ]
        }
      ]
    }
  ]
}